rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orgs/{orgId}/events/{eventId} {
      allow read: if true;
      allow write: if true;
    }
    match /orgs/{orgId}/presence/{userId} {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
