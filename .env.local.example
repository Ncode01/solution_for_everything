# Copy to .env.local — fill after running pnpm db:seed
#
# Must match between local dev, Vercel, and Railway where noted.
# See docs/DEPLOY.md and docs/TROUBLESHOOTING.md

# Frontend origin (Better Auth + browser) — no trailing slash
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Fastify API (Railway locally: pnpm dev:server)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Org UUID from pnpm db:seed output
NEXT_PUBLIC_ORG_ID=

# Copy DATABASE_URL from .env.server (required for Better Auth API routes)
DATABASE_URL=

# Must match BETTER_AUTH_SECRET on Railway
BETTER_AUTH_SECRET=dev_only_change_me_long_random_string
BETTER_AUTH_URL=http://localhost:3000

# Firebase — project: flowcanvas-live (run: firebase apps:sdkconfig WEB <appId>)
# If missing: [Firebase] env vars missing — app runs without realtime/presence
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=flowcanvas-live.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=flowcanvas-live
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=flowcanvas-live.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
