# =============================================================================
# FlowCanvas — Local frontend (.env.local)
# Copy to .env.local. See docs/DEPLOY.md and docs/TROUBLESHOOTING.md
# =============================================================================

# --- Vercel / browser (NEXT_PUBLIC_* are embedded in the client bundle) ---

# Exact origin of the Next.js app — must match BETTER_AUTH_URL and Railway APP_URL/CORS_ORIGIN
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Public URL of the Fastify API (Railway in production)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Organization UUID — output of: pnpm db:seed (required for graph/canvas)
NEXT_PUBLIC_ORG_ID=

# --- Next.js server routes (Better Auth — NOT exposed to browser) ---

# Same Neon DB as Railway — required for /api/auth on localhost
DATABASE_URL=

# Must be identical on Vercel and Railway
BETTER_AUTH_SECRET=dev_only_change_me_long_random_string

# Must equal NEXT_PUBLIC_APP_URL (no trailing slash)
BETTER_AUTH_URL=http://localhost:3000

# --- Firebase (optional — app works without realtime/presence) ---

# If any key is missing: [Firebase] env vars missing — events/presence disabled
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=flowcanvas-live.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=flowcanvas-live
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=flowcanvas-live.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# =============================================================================
# Railway API vars live in .env.server — see .env.server.example
# =============================================================================
