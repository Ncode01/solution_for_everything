# =============================================================================
# FlowCanvas — Local API server (.env.server)
# Copy to .env.server. Used by: pnpm dev:server, Railway/Render production
# =============================================================================

# --- Neon (required) ---

DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# --- Server bind ---

PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# --- Auth & CORS (must match Vercel NEXT_PUBLIC_APP_URL exactly) ---

# Frontend origin allowed by CORS — production: https://your-app.vercel.app
# Preview: set to that preview URL or API calls return CORS errors
APP_URL=http://localhost:3000
CORS_ORIGIN=http://localhost:3000

# Must match BETTER_AUTH_SECRET on Vercel
BETTER_AUTH_SECRET=dev_only_change_me_long_random_string

# Must match NEXT_PUBLIC_APP_URL on Vercel
BETTER_AUTH_URL=http://localhost:3000

# Legacy — prefer BETTER_AUTH_SECRET
JWT_SECRET=dev_only_change_me
