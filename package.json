{
  "name": "flowcanvas",
  "version": "0.1.0",
  "private": true,
  "description": "Org-wide spatial task management on an infinite ReactFlow canvas",
  "scripts": {
    "dev": "next dev",
    "dev:server": "tsx watch --env-file=.env.server server/index.ts",
    "dev:all": "concurrently -n web,api -c blue,green \"pnpm dev\" \"pnpm dev:server\"",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc -p server/tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:seed": "tsx --env-file=.env.server server/db/seed.ts",
    "auth:seed": "tsx --env-file=.env.server scripts/auth-seed.ts",
    "auth:link-owner": "tsx --env-file=.env.server --env-file=.env.local scripts/link-owner.ts",
    "build:server": "tsc -p server/tsconfig.json",
    "diagnose": "tsx --env-file=.env.server scripts/diagnose.ts",
    "diagnose:prod": "tsx scripts/diagnose-prod.ts",
    "start:server": "node server/dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@9.0.0",
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@neondatabase/serverless": "^1.0.2",
    "@tanstack/react-query": "^5.100.14",
    "@xyflow/react": "^12.10.2",
    "better-auth": "^1.6.11",
    "cmdk": "^1.1.1",
    "dotenv": "^17.2.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "firebase": "^12.0.0",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.16.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "recharts": "^3.8.1",
    "zustand": "^5.0.13"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.4",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3"
  }
}
